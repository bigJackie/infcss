{
  "name": "inf-css",
  "type": "module",
  "version": "0.0.1",
  "description": "Atom css framework",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./vite": {
      "import": "./dist/vite.mjs",
      "require": "./dist/vite.cjs"
    }
  },
  "files": [
    "index.js",
    "dist"
  ],
  "scripts": {
    "build": "unbuild"
  },
  "dependencies": {
    "@infcss/core": "workspace:*",
    "@infcss/vite": "workspace:*",
    "@infcss/shared": "workspace:*",
    "@infcss/presets": "workspace:*"
  },
  "devDependencies": {
    "unbuild": "^3.6.1"
  },
  "keywords": [
    "css",
    "atom"
  ],
  "author": "JackieWong",
  "license": "MIT"
}
