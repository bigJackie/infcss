{
  "name": "@jackiew/infcss",
  "type": "module",
  "version": "0.0.1",
  "description": "Atom css framework",
  "scripts": {
    "publish:all": "pnpm -r --filter=./packages/* publish --access public --no-git-checks --registry https://registry.npmjs.org/",
    "clean": "rimraf --glob **/node_modules packages/*/dist",
    "build": "rimraf packages/*/dist --glob && pnpm -r --filter=./packages/* run build",
    "build:interactive": "pnpm run build && pnpm -C interactive run build",
    "interactive": "pnpm -C interactive run dev",
    "lint": "npx prettier --write . && npx eslint --fix .",
    "test": "vitest",
    "coverage": "vitest run --coverage"
  },
  "keywords": [
    "css",
    "atom",
    "infcss"
  ],
  "author": "JackieWong",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "esbuild": "^0.28.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
