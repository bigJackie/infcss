{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "nodenext",
    "types": ["node"],
    "lib": ["ESNext", "DOM"],
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "strict": true,
    "paths": {
      "@infcss/core": ["./packages/core/src/index.ts"],
      "@infcss/vite": ["./packages/vite/src/index.ts"],
      "@infcss/shared": ["./packages/shared/src/index.ts"],
      "@infcss/config": ["./packages/config/src/index.ts"],
      "@infcss/presets": ["./packages/presets/src/index.ts"]
    }
  },
  "exclude": ["**/dist/**", "**/node_modules/**"]
}
